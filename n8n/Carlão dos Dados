      "parameters": {
        "jsCode": "// Gera URLs de gráficos via QuickChart (sem necessidade de API key)\nconst d = $input.first().json;\nconst hist = d.historico_30d || [];\n\nconst labels = hist.map(h => {\n  const dt = new Date(h.data_referencia);\n  return `${String(dt.getDate()).padStart(2,'0')}/${String(dt.getMonth()+1).padStart(2,'0')}`;\n});\n\n// Adiciona dia atual\nconst dRef = new Date(d.data_referencia);\nlabels.push(`${String(dRef.getDate()).padStart(2,'0')}/${String(dRef.getMonth()+1).padStart(2,'0')}`);\n\nconst cadastrosData = [...hist.map(h => Number(h.novos_cadastros) || 0), d.novos_cadastros];\nconst dauData = [...hist.map(h => Number(h.dau) || 0), d.dau];\nconst cacData = [...hist.map(h => Number(h.cac_blended_brl) || 0), d.cac_blended_brl];\nconst ecpmData = [...hist.map(h => Number(h.ecpm_brl) || 0), d.ecpm_brl];\n\nconst makeChart = (config) => {\n  return 'https://quickchart.io/chart?bkg=white&w=600&h=300&c=' + encodeURIComponent(JSON.stringify(config));\n};\n\nconst grafico_cadastros = makeChart({\n  type: 'line',\n  data: {\n    labels,\n    datasets: [{ label: 'Novos cadastros', data: cadastrosData, borderColor: '#16a34a', backgroundColor: 'rgba(22,163,74,0.1)', fill: true, tension: 0.3 }]\n  },\n  options: { plugins: { title: { display: true, text: 'Novos cadastros — 30 dias' } } }\n});\n\nconst grafico_dau = makeChart({\n  type: 'line',\n  data: {\n    labels,\n    datasets: [{ label: 'DAU', data: dauData, borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,0.1)', fill: true, tension: 0.3 }]\n  },\n  options: { plugins: { title: { display: true, text: 'Usuários ativos diários (DAU)' } } }\n});\n\nconst grafico_cac = makeChart({\n  type: 'bar',\n  data: {\n    labels,\n    datasets: [{ label: 'CAC (R$)', data: cacData, backgroundColor: '#f59e0b' }]\n  },\n  options: { plugins: { title: { display: true, text: 'CAC blended diário (R$)' } } }\n});\n\nconst grafico_ecpm = makeChart({\n  type: 'line',\n  data: {\n    labels,\n    datasets: [{ label: 'eCPM (R$)', data: ecpmData, borderColor: '#9333ea', backgroundColor: 'rgba(147,51,234,0.1)', fill: true, tension: 0.3 }]\n  },\n  options: { plugins: { title: { display: true, text: 'eCPM AdMob (R$)' } } }\n});\n\nreturn [{ json: { ...d, graficos: { grafico_cadastros, grafico_dau, grafico_cac, grafico_ecpm } } }];"
