        "jsCode": "const raw = $input.first().json;\n\nlet text = '';\nif (raw.content && Array.isArray(raw.content) && raw.content[0]?.text) {\n  text = raw.content[0].text;\n} else if (typeof raw === 'string') {\n  text = raw;\n} else if (raw.text) {\n  text = raw.text;\n} else if (raw.completion) {\n  text = raw.completion;\n} else {\n  text = JSON.stringify(raw);\n}\n\n// Detectar truncamento: stop_reason === 'max_tokens' indica resposta cortada\nconst stopReason = raw.stop_reason || raw.stopReason;\nconst truncated = stopReason === 'max_tokens';\n\n// Remover markdown fences se vierem\ntext = text.trim()\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/```\\s*$/i, '')\n  .trim();\n\n// Extrair só do primeiro { até o último }\nconst firstBrace = text.indexOf('{');\nconst lastBrace = text.lastIndexOf('}');\nif (firstBrace >= 0 && lastBrace > firstBrace) {\n  text = text.slice(firstBrace, lastBrace + 1);\n}\n\nlet parsed;\ntry {\n  parsed = JSON.parse(text);\n} catch (e) {\n  if (truncated) {\n    throw new Error(\n      `Resposta do Claude foi truncada (stop_reason=max_tokens). ` +\n      `Aumente max_tokens no nó anterior. Erro de parse: ${e.message}`\n    );\n  }\n  throw new Error(`JSON inválido do Carlos: ${e.message}\\nOutput: ${text.slice(0, 500)}...`);\n}\n\nreturn [{ json: { ...parsed, _truncated: truncated, _stop_reason: stopReason } }];"
      },
