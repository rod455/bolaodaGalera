        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"query\": \"SELECT customer.id, metrics.cost_micros, metrics.impressions, metrics.clicks, metrics.ctr, metrics.conversions FROM customer WHERE segments.date = '{{ $('Definir contexto temporal').item.json.data_referencia }}'\"\n}",
