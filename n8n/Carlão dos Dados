        "jsCode": "const data = $input.first().json;\nconst dataRef = $('Definir contexto temporal').first().json.data_referencia;\n\nconst farolEmoji = {verde: '🟢', amarelo: '🟡', vermelho: '🔴'}[data.farol] || '⚪';\nconst farolColor = {verde: '#22c55e', amarelo: '#eab308', vermelho: '#ef4444'}[data.farol] || '#9ca3af';\n\nconst renderInsights = (insights = []) => insights.map(i => `\n  <div style=\"margin-bottom:16px;padding:12px;background:#f9fafb;border-left:3px solid #3b82f6;border-radius:4px;\">\n    <div style=\"font-weight:600;color:#111827;margin-bottom:4px;\">${i.titulo}</div>\n    <div style=\"color:#374151;font-size:14px;\">${i.descricao}</div>\n    <div style=\"margin-top:6px;font-size:12px;color:#6b7280;\">\n      <span style=\"text-transform:uppercase;\">${i.categoria}</span> · \n      <span>importância: ${i.importancia}</span>\n    </div>\n  </div>\n`).join('');\n\nconst renderAlertas = (alertas = []) => alertas.map(a => `\n  <div style=\"margin-bottom:12px;padding:12px;background:#fef2f2;border-left:3px solid #ef4444;border-radius:4px;\">\n    <div style=\"font-weight:600;color:#991b1b;margin-bottom:4px;text-transform:uppercase;font-size:12px;\">${a.tipo} · ${a.severidade}</div>\n    <div style=\"color:#374151;font-size:14px;\">${a.mensagem}</div>\n  </div>\n`).join('');\n\nconst renderAcoes = (acoes = []) => acoes.map(a => `\n  <div style=\"margin-bottom:12px;padding:12px;background:#eff6ff;border-left:3px solid #2563eb;border-radius:4px;\">\n    <div style=\"font-weight:600;color:#1e3a8a;margin-bottom:4px;\">${a.prioridade} · ${a.acao}</div>\n    <div style=\"color:#374151;font-size:14px;margin-bottom:4px;\">${a.justificativa}</div>\n    <div style=\"font-size:12px;color:#6b7280;\">prazo: ${a.prazo} · impacto: ${a.impacto_esperado}</div>\n  </div>\n`).join('');\n\nconst html = `<!DOCTYPE html>\n<html><head><meta charset=\"utf-8\"><title>Carlão D-1 ${dataRef}</title></head>\n<body style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f3f4f6;margin:0;padding:24px;\">\n  <div style=\"max-width:680px;margin:0 auto;background:#fff;border-radius:8px;padding:32px;\">\n    <div style=\"border-bottom:2px solid #e5e7eb;padding-bottom:16px;margin-bottom:24px;\">\n      <div style=\"font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;\">Carlão dos Dados · ${dataRef}</div>\n      <h1 style=\"margin:8px 0 0;font-size:24px;color:#111827;\">${farolEmoji} OnePage Diário</h1>\n    </div>\n\n    <div style=\"background:${farolColor}15;border-left:4px solid ${farolColor};padding:16px;margin-bottom:24px;border-radius:4px;\">\n      <div style=\"font-weight:600;color:#111827;margin-bottom:8px;\">Resumo executivo</div>\n      <div style=\"color:#374151;line-height:1.5;\">${data.resumo_executivo}</div>\n      <div style=\"margin-top:12px;font-size:13px;color:#6b7280;font-style:italic;\">${data.farol_justificativa}</div>\n    </div>\n\n    <h2 style=\"font-size:16px;color:#111827;margin:24px 0 12px;border-bottom:1px solid #e5e7eb;padding-bottom:6px;\">💡 Insights</h2>\n    ${renderInsights(data.insights)}\n\n    <h2 style=\"font-size:16px;color:#111827;margin:24px 0 12px;border-bottom:1px solid #e5e7eb;padding-bottom:6px;\">🚨 Alertas</h2>\n    ${renderAlertas(data.alertas)}\n\n    <h2 style=\"font-size:16px;color:#111827;margin:24px 0 12px;border-bottom:1px solid #e5e7eb;padding-bottom:6px;\">🎯 Ações recomendadas</h2>\n    ${renderAcoes(data.acoes_recomendadas)}\n\n    <h2 style=\"font-size:16px;color:#111827;margin:24px 0 12px;border-bottom:1px solid #e5e7eb;padding-bottom:6px;\">📊 Análise completa</h2>\n    <div style=\"color:#374151;line-height:1.6;font-size:14px;white-space:pre-wrap;\">${data.analise_completa}</div>\n\n    ${data.fontes_pendentes?.length ? `\n    <div style=\"margin-top:32px;padding:12px;background:#fffbeb;border-radius:4px;font-size:12px;color:#92400e;\">\n      ⚠️ Fontes pendentes de configuração: ${data.fontes_pendentes.join(', ')}\n    </div>` : ''}\n\n    <div style=\"margin-top:32px;padding-top:16px;border-top:1px solid #e5e7eb;font-size:11px;color:#9ca3af;text-align:center;\">\n      Gerado por Carlão · Bolão na Copa\n    </div>\n  </div>\n</body></html>`;\n\nreturn [{ json: { ...data, html } }];"
      },
